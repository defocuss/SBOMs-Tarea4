uest, causing denial‑of‑service for endpoints serving files (e.g., StaticFiles or any use of FileResponse). This vulnerability is fixed in 0.49.1.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-62727","epss":0.00398,"percentile":0.60631,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2025-62727","cwe":"CWE-407","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"starlette","version":"0.46.2"}},"found":{"vulnerabilityID":"GHSA-7f5h-v6xp-fcq8","versionConstraint":">=0.39.0,<=0.49.0 (python)"},"fix":{"suggestedVersion":"0.49.1"}}],"artifact":{"id":"286595c7cfc95199","name":"starlette","version":"0.46.2","type":"python","locations":[{"path":"/uv.lock","accessPath":"/uv.lock","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:encode:starlette:0.46.2:*:*:*:*:python:*:*"],"purl":"pkg:pypi/starlette@0.46.2","upstreams":[]}},{"vulnerability":{"id":"GHSA-2c2j-9gv5-cj73","dataSource":"https://github.com/advisories/GHSA-2c2j-9gv5-cj73","namespace":"github:language:python","severity":"Medium","urls":["https://github.com/encode/starlette/security/advisories/GHSA-2c2j-9gv5-cj73","https://github.com/encode/starlette/commit/9f7ec2eb512fcc3fe90b43cb9dd9e1d08696bec1","https://github.com/encode/starlette/blob/fa5355442753f794965ae1af0f87f9fec1b9a3de/starlette/datastructures.py#L436C5-L447C14","https://github.com/encode/starlette/discussions/2927#discussioncomment-13721403","https://nvd.nist.gov/vuln/detail/CVE-2025-54121"],"description":"Starlette has possible denial-of-service vector when parsing large files in multipart forms","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-54121","epss":0.00226,"percentile":0.45382,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2025-54121","cwe":"CWE-770","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["0.47.2"],"state":"fixed","available":[{"version":"0.47.2","date":"2025-07-22","kind":"first-observed"}]},"advisories":[],"risk":0.11639000000000001},"relatedVulnerabilities":[{"id":"CVE-2025-54121","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-54121","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/encode/starlette/blob/fa5355442753f794965ae1af0f87f9fec1b9a3de/starlette/datastructures.py#L436C5-L447C14","https://github.com/encode/starlette/commit/9f7ec2eb512fcc3fe90b43cb9dd9e1d08696bec1","https://github.com/encode/starlette/discussions/2927#discussioncomment-13721403","https://github.com/encode/starlette/security/advisories/GHSA-2c2j-9gv5-cj73"],"description":"Starlette is a lightweight ASGI (Asynchronous Server Gateway Interface) framework/toolkit, designed for building async web services in Python. In versions 0.47.1 and below, when parsing a multi-part form with large files (greater than the default max spool size) starlette will block the main thread to roll the file over to disk. This blocks the event thread which means the application can't accept new connections. The UploadFile code has a minor bug where instead of just checking for self._in_memory, the logic should also check if the additional bytes will cause a rollover. The vulnerability is fixed in version 0.47.2.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-54121","epss":0.00226,"percentile":0.45382,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2025-54121","cwe":"CWE-770","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"starlette","version":"0.46.2"}},"found":{"vulnerabilityID":"GHSA-2c2j-9gv5-cj73","versionConstraint":"<0.47.2 (python)"},"fix":{"suggestedVersion":"0.47.2"}}],"artifact":{"id":"286595c7cfc95199","name":"starlette","version":"0.46.2","type":"python","locations":[{"path":"/uv.lock","accessPath":"/uv.lock","annotations":{"evidence":"primary"}}],"language":"python","licenses":[],"cpes":["cpe:2.3:a:encode:starlette:0.46.2:*:*:*:*:python:*:*"],"purl":"pkg:pypi/starlette@0.46.2","upstreams":[]}},{"vulnerability":{"id":"GHSA-wp53-j4wj-2cfg","dataSource":"https://github.com/advisories/GHSA-wp53-j4wj-2cfg","namespace":"github:language:python","severity":"High","urls":["https://github.com/Kludex/python-multipart/security/advisories/GHSA-wp53-j4wj-2cfg","https://github.com/Kludex/python-multipart/commit/9433f4bbc9652bdde82bbe380984e32f8cfc89c4","https://github.com/Kludex/python-multipart/releases/tag/0.0.22","https://nvd.nist.gov/vuln/detail/CVE-2026-24486"],"description":"Python-Multipart has Arbitrary File Write via Non-Default Configuration","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:H/A:L","metrics":{"baseScore":8.6,"exploitabilityScore":3.9,"impactScore":4.8},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-24486","epss":0.0003,"percentile":0.08489,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-24486","cwe":"CWE-22","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.0.22"],"state":"fixed","available":[{"version":"0.0.22","date":"2026-01-27","kind":"first-observed"}]},"advisories":[],"risk":0.024149999999999998},"relatedVulnerabilities":[{"id":"CVE-2026-24486","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-24486","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/Kludex/python-multipart/commit/9433f4bbc9652bdde82bbe380984e32f8cfc89c4","https://github.com/Kludex/python-multipart/releases/tag/0.0.22","https://github.com/Kludex/python-multipart/security/advisories/GHSA-wp53-j4wj-2cfg"],"description":"Python-Multipart is a streaming multipart parser for Python. Prior to version 0.0.22, a Path Traversal vulnerability exists when using non-default configuration options `UPLOAD_DIR` and `UPLOAD_KEEP_FILENAME=True`. An attacker can write uploaded files to arbitrary locations on the filesystem by crafting a malicious filename. Users should upgrade to version 0.0.22 to receive a patch or, as a workaround, avoid using `UPLOAD_KEEP_FILENAME=True` in project configurations.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:H/A:N","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:H/A:L","metrics":{"baseScore":8.6,"exploitabilityScore":3.9,"impactScore":4.8},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-24486","epss":0.0003,"percentile":0.08489,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-24486","cwe":"CWE-22","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"python-matcher","searchedBy":{"language":"python","namespace":"github:language:python","package":{"name":"python-multipart","version":"0.0.21"}},"found":{"vulnerabilityID":"GHSA-wp53-j4wj-2cfg","versionConstraint":"<0.0.22 (python)"},"fix":{"suggestedVersion":"0.0.22"}}],"artifact":{"id":"f3c25e5a89af8cb8","name":"python-multipart","version":"0.0.21","type":"python","locations":[{"path":"/uv.lock","accessPath":"/uv.lock","annotations":{"evidence":"primary"}}],"language":"python","licenses":